#!/bin/sh
set -eu

project_root=$(CDPATH= cd -- "$(dirname -- "$0")/../.." && pwd)
tmpdir=$(/usr/bin/mktemp -d "${TMPDIR:-/tmp}/semantouch-codesign-parser.XXXXXX")
trap '/bin/rm -rf "$tmpdir"' EXIT HUP INT TERM

fixture='Executable=/tmp/Semantouch.app/Contents/MacOS/semantouch
Identifier=tech.watzon.semantouch.cli
Format=Mach-O universal (x86_64 arm64)
CodeDirectory v=20500 size=1234 flags=0x10000(runtime) hashes=28+7 location=embedded
Authority=Developer ID Application: Watzon Ventures LLc (MB5789APU7)
TeamIdentifier=MB5789APU7
Timestamp=Jul 14, 2026 at 8:00:00 PM'

for source in "$project_root/scripts/verify-app-release" "$project_root/scripts/semantouch"; do
  harness="$tmpdir/$(basename -- "$source").sh"
  /usr/bin/awk '
    /^codesign_field\(\) \{/ { copying = 1 }
    copying { print }
    copying && /^}$/ { exit }
  ' "$source" > "$harness"

  if [ ! -s "$harness" ]; then
    printf '%s\n' "codesign-field-parser: codesign_field not found in $source" >&2
    exit 1
  fi

  cat >> "$harness" <<'EOF'

fixture=$FIXTURE

assert_field() {
  expected=$1
  field=$2
  actual=$(codesign_field "$fixture" "$field")
  if [ "$actual" != "$expected" ]; then
    printf '%s\n' "codesign-field-parser: $field=$actual expected $expected" >&2
    exit 1
  fi
}

assert_field 'tech.watzon.semantouch.cli' Identifier
assert_field 'MB5789APU7' TeamIdentifier
assert_field 'Developer ID Application: Watzon Ventures LLc (MB5789APU7)' Authority
assert_field '0x10000(runtime)' flags
EOF

  FIXTURE=$fixture /bin/sh -c '. "$1"' sh "$harness"
done

# A bundle's CFBundleExecutable signature seals Info.plist. Verify it in place:
# detaching the same bytes must fail, which guards the verifier's host mode.
test_app="$tmpdir/Test.app"
test_host="$test_app/Contents/MacOS/TestHost"
/bin/mkdir -p "$(dirname -- "$test_host")"
/bin/cat /bin/echo > "$test_host"
/bin/chmod 0755 "$test_host"
/bin/cat > "$test_app/Contents/Info.plist" <<'EOF'
<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
  <key>CFBundleExecutable</key>
  <string>TestHost</string>
  <key>CFBundleIdentifier</key>
  <string>tech.watzon.semantouch.codesign-regression</string>
  <key>CFBundlePackageType</key>
  <string>APPL</string>
</dict>
</plist>
EOF
/usr/bin/codesign --force --options runtime --sign - "$test_app"
/usr/bin/codesign --verify --deep --strict "$test_host"

detached_host="$tmpdir/TestHost.detached"
/bin/cat "$test_host" > "$detached_host"
/bin/chmod 0755 "$detached_host"
if /usr/bin/codesign --verify --strict "$detached_host" >/dev/null 2>&1; then
  printf '%s\n' 'codesign-field-parser: detached CFBundleExecutable unexpectedly verified' >&2
  exit 1
fi

printf '%s\n' 'codesign-field-parser: ok'
