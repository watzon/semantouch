#!/bin/sh
set -eu

if [ "$#" -lt 1 ] || [ "$#" -gt 2 ]; then
  printf '%s\n' "usage: $0 /path/to/semantouch [notarytool-keychain-profile]" >&2
  exit 2
fi

binary=$1
profile=${2:-notarytool-password}
temp_dir=$(/usr/bin/mktemp -d "${TMPDIR:-/tmp}/semantouch-notary.XXXXXX")
trap '/bin/rm -rf "$temp_dir"' EXIT HUP INT TERM
archive="$temp_dir/semantouch.zip"
result="$temp_dir/notarization.json"

/usr/bin/ditto -c -k --keepParent "$binary" "$archive"
/usr/bin/xcrun notarytool submit "$archive" \
  --keychain-profile "$profile" \
  --wait \
  --output-format json > "$result"

status=$(/usr/bin/plutil -extract status raw "$result")
if [ "$status" != "Accepted" ]; then
  summary=$(/usr/bin/plutil -extract statusSummary raw "$result" 2>/dev/null || printf '%s' "Unknown notarization failure")
  printf '%s\n' "semantouch: notarization failed: $status - $summary" >&2
  exit 1
fi

printf '%s\n' "semantouch: notarization accepted for $binary"
